---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const categories = [
  {
    title: 'IT',
    description: 'Windows & Linux tooling, homelab experiments and web development projects.',
    href: '/projects/it/',
    image: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=1200&q=80',
  },
  {
    title: 'DESIGN',
    description: 'Motion design, animation and visual experiments projects.',
    href: '/projects/design/',
    image: 'https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&w=1200&q=80',
  },
  {
    title: 'MUSIC',
    description: 'Song writing, AI sound design, music projects.',
    href: '/projects/music/',
    image: 'https://images.unsplash.com/photo-1514320291840-2e0a9bf2a9ae?auto=format&fit=crop&w=1200&q=80',
  },
];
---

<BaseLayout
  title="Projects - Vuk1lis"
  description="Explore projects across IT, Design, and Music"
>
  <Navigation />

  <main class="projects-page" id="main-content">
    <div class="container">
      <header class="projects-header">
        <h1 class="page-title">Projects</h1>
        <p class="page-subtitle">
          Select a category to explore
        </p>
      </header>

      <div class="category-grid">
        {categories.map((category) => (
          <a href={category.href} class="category-card">
            <div class="category-card-image" style={`background-image: url('${category.image}');`}></div>
            <div class="category-card-overlay"></div>
            <div class="category-card-content">
              <h2 class="category-title">{category.title}</h2>
              <p class="category-description">{category.description}</p>
              <span class="category-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .projects-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 4rem) 2rem 5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-dim);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    border-radius: 1.5rem;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 420px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--color-bg-card);
  }

  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .category-card-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0.85;
  }

  .category-card:hover .category-card-image {
    transform: scale(1.05);
    opacity: 1;
  }

  .category-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15, 23, 42, 0.95) 0%,
      rgba(15, 23, 42, 0.7) 40%,
      rgba(15, 23, 42, 0.2) 100%
    );
    transition: background 0.3s ease;
  }

  .category-card:hover .category-card-overlay {
    background: linear-gradient(
      to top,
      rgba(15, 23, 42, 0.98) 0%,
      rgba(15, 23, 42, 0.75) 40%,
      rgba(15, 23, 42, 0.3) 100%
    );
  }

  .category-card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    flex-grow: 1;
    justify-content: flex-end;
    margin-top: auto;
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: white;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

  .category-description {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin-bottom: 2rem;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
  }

  .category-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .category-card:hover .category-arrow {
    background: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateX(8px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4);
  }

  @media (max-width: 768px) {
    .projects-page {
      padding-top: calc(var(--nav-height) + 2rem);
    }

    .category-grid {
      grid-template-columns: 1fr;
    }

    .category-card {
      min-height: 320px;
      padding: 2rem;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About - Vuk1lis" description="Vuk1lis is a DevOps engineer, Linux enthusiast, and VibeCoder. He shares his knowledge and experience through blog posts, tutorials, and open-source projects.">
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title">About Me</h1>

      <div class="content-grid">
        <section class="content-section intro-section">
          <h2>Hello, I'm Vuk1lis</h2>
          <p>
            I'm a DevOps engineer, Linux enthusiast, and VibeCoder passionate about building immersive digital experiences.
            My work sits at the intersection of art and technology, where I explore the possibilities of
            modern web technologies to create visually striking, motion-rich interfaces.
          </p>
          <p>
            With a deep love for dark aesthetics and smooth animations, I specialize in crafting websites
            that aren't just functional—they're experiences that captivate and engage users from the moment
            they land on the page.
          </p>
        </section>

        <section class="content-section">
          <h2>What I Do</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <circle cx="12" cy="12" r="6"></circle>
                  <circle cx="12" cy="12" r="2"></circle>
                </svg>
              </div>
              <h3>Creative Development</h3>
              <p>Building unique web experiences with Three.js, WebGL, and advanced CSS animations.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
              </div>
              <h3>Performance Optimization</h3>
              <p>Ensuring smooth 60fps animations and optimal loading times with modern tooling.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </div>
              <h3>3D Graphics</h3>
              <p>Creating particle systems, geometric patterns, and interactive 3D elements for the web.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
              </div>
              <h3>Dark UI Design</h3>
              <p>Designing beautiful dark-themed interfaces with carefully crafted color palettes.</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>My Approach</h2>
          <p>
            I believe that motion is emotion. Every animation, every transition, every particle movement
            should have a purpose—to guide, to delight, or to immerse. I'm constantly pushing the boundaries
            of what's possible on the web, experimenting with new techniques and technologies.
          </p>
          <p>
            Whether it's a personal blog, a portfolio site, or a complex web application, I approach each
            project with the same goal: create something that stands out, performs well, and provides an
            unforgettable user experience.
          </p>
        </section>

        <section class="content-section cta-section">
          <h2>Let's Connect</h2>
          <p>Interested in working together or just want to chat about web animations and dark design?</p>
          <div class="contact-buttons">
            <a href={`${base}projects/`} class="btn btn-primary">
              View My Work
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a href={`${base}blog/`} class="btn btn-secondary">Read My Blog</a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text);
  }

  .content-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-section {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .content-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .content-section p {
    line-height: 1.7;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .what-i-do-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .service-card {
    padding: 1.25rem;
    background: rgba(59, 130, 246, 0.05);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .cta-section {
    text-align: center;
  }

  .cta-section p {
    margin-bottom: 1.5rem;
  }

  .contact-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: #2563EB;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: calc(var(--nav-height) + 1rem);
    }

    .what-i-do-grid {
      grid-template-columns: 1fr;
    }

    .contact-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

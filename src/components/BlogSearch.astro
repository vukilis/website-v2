---
interface Props {
  posts: { id: string; data: { title: string } }[];
}

const { posts } = Astro.props;
---

<div class="blog-search-wrapper" id="blog-search-wrapper">
  <div class="blog-search" id="blog-search">
    <div class="search-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" x2="16.65" y1="21" y2="16.65" />
      </svg>
    </div>
    <input
      type="text"
      id="blog-search-input"
      class="search-input"
      placeholder="Search posts..."
      autocomplete="off"
      role="combobox"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="blog-search-suggestions"
      aria-label="Search blog posts by title"
    />
    <button
      id="blog-search-clear"
      class="search-clear"
      aria-label="Clear search"
      type="button"
      hidden
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" x2="6" y1="6" y2="18" />
        <line x1="6" x2="18" y1="6" y2="18" />
      </svg>
    </button>
    <ul
      id="blog-search-suggestions"
      class="search-suggestions"
      role="listbox"
      hidden
    ></ul>
    <div id="blog-search-status" class="search-status" hidden>
      <span class="search-status-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" x2="16.65" y1="21" y2="16.65" />
        </svg>
      </span>
      <span class="search-status-text" id="blog-search-status-text"></span>
    </div>
  </div>
</div>

<script is:inline>
  function scheduleInit(id) {
    var key = '__blog_search_initialized_' + id;
    if (window[key]) {
      window[key] = false;
    }
    var wrapper = function () { return document.getElementById(id); };
    var init = function () {
      var root = wrapper();
      if (!root) return;

      var input = root.querySelector('.search-input');
      var clearBtn = root.querySelector('.search-clear');
      var suggestionsList = root.querySelector('.search-suggestions');
      var statusBar = root.querySelector('.search-status');
      var statusText = root.querySelector('.search-status-text');

      if (!input || !clearBtn || !suggestionsList || !statusBar || !statusText) return;

      var blogCards = document.querySelectorAll('.blog-card');
      if (blogCards.length === 0) return;

      var postMap = new Map();
      var postTitles = Array.from(blogCards).map(function (card) {
        var titleEl = card.querySelector('.blog-title');
        var title = titleEl ? (titleEl.textContent || '').trim() : '';
        var slug = card.getAttribute('href') || '';
        postMap.set(title.toLowerCase(), { title: title, slug: slug, card: card });
        return title;
      });

      var currentQuery = '';
      var currentQueryField = input;
      var activeIndex = -1;
      var currentSuggestions = [];

      function highlightMatch(text, query) {
        if (!query) return text;
        var escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        var regex = new RegExp('(' + escaped + ')', 'gi');
        return text.replace(regex, '<mark class="search-highlight">$1</mark>');
      }

      function createSuggestionItem(title, query, index) {
        var li = document.createElement('li');
        li.className = 'search-suggestion';
        li.setAttribute('role', 'option');
        li.setAttribute('aria-selected', 'false');

        var icon = document.createElement('span');
        
        var titleSpan = document.createElement('span');
        titleSpan.className = 'suggestion-title';
        titleSpan.innerHTML = highlightMatch(title, query);

        var arrow = document.createElement('span');
        arrow.className = 'suggestion-arrow';
        arrow.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';

        li.appendChild(icon);
        li.appendChild(titleSpan);
        li.appendChild(arrow);

        li.addEventListener('click', function () {
          selectSuggestion(title);
        });
        li.addEventListener('mouseenter', function () {
          setActiveSuggestion(index);
        });

        return li;
      }

      function renderSuggestions(query) {
        currentSuggestions = [];
        suggestionsList.innerHTML = '';

        if (!query.trim()) {
          suggestionsList.hidden = true;
          input.setAttribute('aria-expanded', 'false');
          return;
        }

        var lowerQuery = query.toLowerCase();
        var matches = postTitles
          .map(function (title, idx) { return { title: title, idx: idx }; })
          .filter(function (item) { return item.title.toLowerCase().indexOf(lowerQuery) !== -1; })
          .slice(0, 8);

        if (matches.length === 0) {
          var emptyLi = document.createElement('li');
          emptyLi.className = 'search-suggestion empty';
          emptyLi.setAttribute('role', 'option');
          emptyLi.setAttribute('aria-selected', 'false');
          emptyLi.innerHTML = '<span class="suggestion-empty-icon"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" x2="16.65" y1="21" y2="16.65"/></svg></span><span class="suggestion-empty-text">No posts match "<strong>' + query.replace(/"/g, '') + '</strong>"</span>';
          suggestionsList.appendChild(emptyLi);
          suggestionsList.hidden = false;
          input.setAttribute('aria-expanded', 'true');
          currentSuggestions = [];
          activeIndex = -1;
          return;
        }

        var headerLi = document.createElement('li');
        headerLi.className = 'suggestions-header';
        headerLi.setAttribute('aria-hidden', 'true');
        headerLi.textContent = matches.length + ' suggestion' + (matches.length > 1 ? 's' : '') + ' found';
        suggestionsList.appendChild(headerLi);

        var divider = document.createElement('li');
        divider.className = 'suggestions-divider';
        divider.setAttribute('aria-hidden', 'true');
        suggestionsList.appendChild(divider);

        matches.forEach(function (item, i) {
          var li = createSuggestionItem(item.title, query, i);
          suggestionsList.appendChild(li);
        });

        suggestionsList.hidden = false;
        input.setAttribute('aria-expanded', 'true');
        currentSuggestions = matches;
        activeIndex = 0;
        setActiveSuggestion(0);
      }

      function setActiveSuggestion(index) {
        activeIndex = index;
        var items = suggestionsList.querySelectorAll('.search-suggestion:not(.empty)');
        items.forEach(function (item, i) {
          var isActive = i === index;
          item.setAttribute('aria-selected', String(isActive));
          item.classList.toggle('active', isActive);
        });

        if (items[index]) {
          items[index].scrollIntoView({ block: 'nearest' });
        }
      }

      function selectSuggestion(title) {
        var entry = postMap.get(title.toLowerCase());
        if (!entry) return;
        input.value = entry.title;
        currentQuery = entry.title;
        clearBtn.hidden = false;
        input.classList.add('has-value');
        hideSuggestions();
        applySearch();
        entry.card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        entry.card.style.transition = 'box-shadow 0.4s ease, border-color 0.4s ease';
        entry.card.style.borderColor = 'var(--color-primary, #3B82F6)';
        entry.card.style.boxShadow = '0 0 0 4px rgba(59, 130, 246, 0.2), 0 8px 30px rgba(59, 130, 246, 0.15)';
        setTimeout(function () {
          entry.card.style.borderColor = '';
          entry.card.style.boxShadow = '';
        }, 2000);
      }

      function hideSuggestions() {
        suggestionsList.hidden = true;
        suggestionsList.innerHTML = '';
        input.setAttribute('aria-expanded', 'false');
        currentSuggestions = [];
        activeIndex = -1;
      }

      function applySearch() {
        var query = currentQuery.trim().toLowerCase();
        var visibleCount = 0;

        blogCards.forEach(function (card) {
          var titleEl = card.querySelector('.blog-title');
          if (!titleEl) return;
          var match = query === '' || (titleEl.textContent || '').toLowerCase().indexOf(query) !== -1;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
      }

      input.addEventListener('input', function () {
        currentQuery = input.value;
        clearBtn.hidden = currentQuery === '';
        if (currentQuery.trim() !== '') {
          input.classList.add('has-value');
        } else {
          input.classList.remove('has-value');
        }
        renderSuggestions(currentQuery);
        applySearch();
      });

      input.addEventListener('keydown', function (e) {
        if (!suggestionsList.hidden && currentSuggestions.length > 0) {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            var next = activeIndex + 1 < currentSuggestions.length ? activeIndex + 1 : 0;
            setActiveSuggestion(next);
            input.value = currentSuggestions[next].title;
            currentQuery = currentSuggestions[next].title;
            return;
          }
          if (e.key === 'ArrowUp') {
            e.preventDefault();
            var prev = activeIndex - 1 >= 0 ? activeIndex - 1 : currentSuggestions.length - 1;
            setActiveSuggestion(prev);
            input.value = currentSuggestions[prev].title;
            currentQuery = currentSuggestions[prev].title;
            return;
          }
          if (e.key === 'Enter') {
            e.preventDefault();
            if (activeIndex >= 0 && activeIndex < currentSuggestions.length) {
              selectSuggestion(currentSuggestions[activeIndex].title);
            } else {
              hideSuggestions();
              applySearch();
            }
            return;
          }
          if (e.key === 'Escape') {
            hideSuggestions();
            return;
          }
        }

        if (e.key === 'Escape') {
          hideSuggestions();
        }
      });

      input.addEventListener('focus', function () {
        if (currentQuery.trim()) {
          renderSuggestions(currentQuery);
        }
      });

      input.addEventListener('blur', function () {
        setTimeout(function () {
          hideSuggestions();
        }, 180);
      });

      clearBtn.addEventListener('click', function () {
        input.value = '';
        currentQuery = '';
        clearBtn.hidden = true;
        input.classList.remove('has-value');
        hideSuggestions();
        input.focus();
        applySearch();
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
          if (currentQuery === '') {
            statusBar.hidden = true;
          }
        }, { once: true });
      }

      applySearch();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  }

  scheduleInit('blog-search');
  document.addEventListener('astro:page-load', function () { scheduleInit('blog-search'); });
</script>
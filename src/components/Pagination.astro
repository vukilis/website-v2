---
interface Props {
  page: Page<any>;
  baseUrl: string;
  showFirstLast?: boolean;
  maxVisible?: number;
}

const {
  page,
  baseUrl,
  showFirstLast = false,
  maxVisible = 5,
} = Astro.props;

const { currentPage, lastPage } = page;

function getPageNumbers(): (number | 'ellipsis')[] {
  if (lastPage <= maxVisible + 2) {
    return Array.from({ length: lastPage }, (_, i) => i + 1);
  }

  const pages: (number | 'ellipsis')[] = [1];
  let left = Math.max(2, currentPage - 1);
  let right = Math.min(lastPage - 1, currentPage + 1);

  if (currentPage <= 3) {
    left = 2;
    right = maxVisible - 1;
  } else if (currentPage >= lastPage - 2) {
    left = Math.max(2, lastPage - maxVisible + 2);
    right = lastPage - 1;
  }

  if (left > 2) pages.push('ellipsis');
  for (let i = left; i <= right; i++) pages.push(i);
  if (right < lastPage - 1) pages.push('ellipsis');
  pages.push(lastPage);

  return pages;
}

const base = baseUrl.replace(/\/$/, '');
const pageNumbers = getPageNumbers();

const prevHref = currentPage > 1 ? `${base}/${currentPage - 1}/` : '';
const nextHref = currentPage < lastPage ? `${base}/${currentPage + 1}/` : '';
const firstHref = `${base}/`;
const lastHref = `${base}/${lastPage}/`;
---

<nav aria-label="Pagination" class="pagination-nav">
  {showFirstLast && (
    currentPage === 1 ? (
      <span class="pagination-icon pagination-disabled" aria-hidden="true" aria-label="First page">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="11 17 6 12 11 7" />
          <polyline points="18 17 13 12 18 7" />
        </svg>
      </span>
    ) : (
      <a href={firstHref} class="pagination-icon" aria-label="First page">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="11 17 6 12 11 7" />
          <polyline points="18 17 13 12 18 7" />
        </svg>
      </a>
    )
  )}

  {prevHref ? (
    <a href={prevHref} class="pagination-icon" aria-label="Previous page">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </a>
  ) : (
    <span class="pagination-icon pagination-disabled" aria-label="Previous page" aria-disabled="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </span>
  )}

  <span class="pagination-pages">
    {pageNumbers.map((p, idx) => {
      if (p === 'ellipsis') {
        return (
          <span class="pagination-ellipsis" aria-hidden="true" key={`ellipsis-${idx}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="1" />
              <circle cx="19" cy="12" r="1" />
              <circle cx="5" cy="12" r="1" />
            </svg>
          </span>
        );
      }

      if (p === currentPage) {
        return <span aria-current="page" class="pagination-current" key={`page-${p}`}>{p}</span>;
      }

      const href = p === 1 ? `${base}/` : `${base}/${p}/`;

      return (
        <a href={href} class="pagination-page" aria-label={`Page ${p}`} key={`page-${p}`}>
          {p}
        </a>
      );
    })}
  </span>

  {nextHref ? (
    <a href={nextHref} class="pagination-icon" aria-label="Next page">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>
  ) : (
    <span class="pagination-icon pagination-disabled" aria-label="Next page" aria-disabled="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </span>
  )}

  {showFirstLast && (
    currentPage === lastPage ? (
      <span class="pagination-icon pagination-disabled" aria-hidden="true" aria-label="Last page">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="13 17 18 12 13 7" />
          <polyline points="6 17 11 12 6 7" />
        </svg>
      </span>
    ) : (
      <a href={lastHref} class="pagination-icon" aria-label="Last page">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="13 17 18 12 13 7" />
          <polyline points="6 17 11 12 6 7" />
        </svg>
      </a>
    )
  )}
</nav>

<style>
  .pagination-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 1.5rem 0 0.75rem;
    margin-top: 2rem;
  }

  .pagination-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-text-dim);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s ease, background 0.15s ease;
    outline: none;
    flex-shrink: 0;
  }

  .pagination-icon:hover:not(.pagination-disabled) {
    color: var(--color-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .pagination-icon:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .pagination-disabled,
  .pagination-disabled:hover {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
    color: var(--color-text-dim);
    background: transparent;
  }

  .pagination-pages {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    margin: 0 0.25rem;
  }

  .pagination-page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.35rem;
    color: var(--color-text-dim);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: color 0.15s ease, background 0.15s ease;
    outline: none;
    user-select: none;
    font-variant-numeric: tabular-nums;
  }

  .pagination-page:hover {
    color: var(--color-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .pagination-page:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .pagination-current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.5rem;
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-body, 'DM Sans', sans-serif);
    border-radius: 0.375rem;
    background: rgba(59, 130, 246, 0.12);
    user-select: none;
    font-variant-numeric: tabular-nums;
  }

  .pagination-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-text-dim);
    opacity: 0.4;
    user-select: none;
  }

  @media (max-width: 640px) {
    .pagination-nav {
      gap: 0.15rem;
      padding: 1.25rem 0 0.5rem;
      margin-top: 1.5rem;
    }

    .pagination-icon {
      width: 1.75rem;
      height: 1.75rem;
    }

    .pagination-icon svg {
      width: 12px;
      height: 12px;
    }

    .pagination-pages {
      gap: 0.1rem;
      margin: 0 0.15rem;
    }

    .pagination-page {
      min-width: 1.75rem;
      height: 1.75rem;
      font-size: 0.75rem;
      padding: 0 0.25rem;
    }

    .pagination-current {
      min-width: 1.75rem;
      height: 1.75rem;
      font-size: 0.75rem;
      padding: 0 0.4rem;
    }

    .pagination-ellipsis {
      width: 1.75rem;
      height: 1.75rem;
    }

    .pagination-ellipsis svg {
      width: 12px;
      height: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pagination-icon,
    .pagination-page,
    .pagination-current {
      transition: none;
    }
  }
</style>

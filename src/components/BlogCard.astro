---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[] | undefined;
  categories?: string[] | undefined;
  activeTag?: string | undefined;
}

const base = import.meta.env.BASE_URL;
const { title, description, pubDate, slug, tags, categories, activeTag } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const tagsJson = JSON.stringify(tags ?? []);
const categoriesJson = JSON.stringify(categories ?? []);
---

<a
  href={`${base}blog/${slug}/`}
  class="blog-card"
  data-tags={tagsJson}
  data-categories={categoriesJson}
>
  <time class="blog-date">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
    </svg>
    {formattedDate}
  </time>
  <h3 class="blog-title">{title}</h3>
  <p class="blog-description">{description}</p>
  {tags && tags.length > 0 && (
    <div class="blog-tags">
      {tags.map((tag) => (
        <span class={`tag${activeTag && activeTag.toLowerCase() === tag.toLowerCase() ? ' active' : ''}`} data-tag={tag} title={`Filter by ${tag}`}>{tag}</span>
      ))}
    </div>
  )}
  <span class="read-more">
    Read article
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </span>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s ease;
    cursor: pointer;
    height: 100%;
  }

  .blog-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.15);
  }

  .blog-date {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-bottom: 0.75rem;
  }

  .blog-date svg {
    opacity: 0.7;
  }

  .blog-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-title {
    color: var(--color-primary);
  }

  .blog-description {
    color: var(--color-text-dim);
    line-height: 1.6;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    padding: 0.25rem 0.625rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-text-dim);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .tag:hover {
    background: rgba(59, 130, 246, 0.12);
    border-color: rgba(59, 130, 246, 0.4);
    color: var(--color-primary);
  }

  .tag.active {
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.5);
    color: var(--color-accent-blue, #3B82F6);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-top: auto;
  }

  .read-more svg {
    transition: transform 0.2s ease;
  }

  .blog-card:hover .read-more svg {
    transform: translateX(4px);
  }
</style>

<script is:inline>
  (function() {
    function init() {
      document.querySelectorAll('.blog-card .tag[data-tag]').forEach(function(el) {
        if (el.getAttribute('data-initialized')) return;
        el.setAttribute('data-initialized', 'true');
        el.style.cursor = 'pointer';
        el.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var tag = el.getAttribute('data-tag');
          if (!tag) return;
          tag = tag.toLowerCase();
          var path = window.location.pathname;
          var tagPage = '/blog/tag/' + encodeURIComponent(tag) + '/';
          if (path === tagPage || path === tagPage.replace(/\/$/, '')) {
            window.location.href = '/blog/';
          } else {
            window.location.href = tagPage;
          }
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>

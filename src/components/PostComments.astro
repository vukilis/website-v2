<section class="giscus mx-auto mt-10 w-full"></section>

<script>
  const giscusContainer = () => document.querySelector('.giscus');

  function loadGiscus(theme) {
    if (theme === undefined) {
      theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    }
    const container = giscusContainer();
    if (!container) return;
    container.innerHTML = '';
    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'vukilis/website-v2');
    script.setAttribute('data-repo-id', 'R_kgDOTflwxg');
    script.setAttribute('data-category', 'Blog Post Comments');
    script.setAttribute('data-category-id', 'DIC_kwDOTflwxs4DBsdu');
    script.setAttribute('data-mapping', 'url');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', 'en');
    script.setAttribute('data-loading', 'lazy');
    script.setAttribute('crossorigin', 'anonymous');
    script.setAttribute('async', '');
    container.appendChild(script);
  }

  loadGiscus();

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadGiscus);
  }

  document.addEventListener('astro:page-load', () => {
    loadGiscus();
  });

  document.addEventListener('theme-changed', (e) => {
    loadGiscus(e.detail.theme);
  });
</script>
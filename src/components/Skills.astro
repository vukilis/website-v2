---
// Skills/Tech Stack section - categorized card layout
---

<section class="skills">
  <div class="container">
    <h2 class="section-title">Skills & Technologies</h2>
    <p class="section-subtitle">Tools and technologies I work with</p>

    <div class="skills-grid">
      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3 class="category-title">AI & VibeCoding</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">AI</span>
          <span class="skill-tag">Frontend</span>
          <span class="skill-tag">Backend</span>
          <span class="skill-tag">n8n</span>
          <span class="skill-tag">Python</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">PowerShell</span>
          <span class="skill-tag">SQL</span>
          <span class="skill-tag">CSS</span>
          <span class="skill-tag">JSON</span>
          <span class="skill-tag">HCL</span>
          <span class="skill-tag">StepFun AI</span>
          <span class="skill-tag">GitHub Copilot</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
          </div>
          <h3 class="category-title">DevOps & Infrastructure</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Linux</span>
          <span class="skill-tag">Git</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Kubernetes</span>
          <span class="skill-tag">AWS</span>
          <span class="skill-tag">Azure</span>
          <span class="skill-tag">NGINX</span>
          <span class="skill-tag">CI/CD</span>
          <span class="skill-tag">Terraform</span>
          <span class="skill-tag">Ansible</span>
          <span class="skill-tag">VMware</span>
          <span class="skill-tag">Proxmox</span>
          <span class="skill-tag">Grafana</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
              <path d="M3 5v14a9 3 0 0 0 18 0V5"></path>
              <path d="M3 12a9 3 0 0 0 18 0"></path>
            </svg>
          </div>
          <h3 class="category-title">Data</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">MongoDB</span>
          <span class="skill-tag">MariaDB</span>
          <span class="skill-tag">Supabase</span>
          <span class="skill-tag">Firebase</span>
          <span class="skill-tag">PostgreSQL</span>
          <span class="skill-tag">MySQL</span>
          <span class="skill-tag">Redis</span>
          <span class="skill-tag">DynamoDB</span>
          <span class="skill-tag">SQLite</span>
        </div>
      </div>

      <div class="skill-category">
        <div class="category-header">
          <div class="category-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
              <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
              <path d="M2 2l7.586 7.586"></path>
              <circle cx="11" cy="11" r="2"></circle>
            </svg>
          </div>
          <h3 class="category-title">Design & Music</h3>
        </div>
        <div class="skill-list">
          <span class="skill-tag">Motion Design</span>
          <span class="skill-tag">Photoshop</span>
          <span class="skill-tag">After Effects</span>
          <span class="skill-tag">Figma</span>
          <span class="skill-tag">AI</span>
          <span class="skill-tag">suno</span>
          <span class="skill-tag">songwriter</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-dim);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-category {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .skill-category:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.15);
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .category-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 0.5rem;
    color: var(--color-primary);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    padding: 0.375rem 0.75rem;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .skill-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .skills {
      padding: 4rem 1.5rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

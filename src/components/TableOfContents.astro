---
interface TocItem {
  id: string;
  text: string;
  depth: number;
  children?: TocItem[];
}

interface Props {
  items?: TocItem[];
  layout?: 'sidebar' | 'card' | 'minimal';
  maxDepth?: number;
}

const {
  items = [],
  layout = 'sidebar',
  maxDepth = 3,
} = Astro.props;
---

<div class="toc" data-layout={layout}>
  <div class="toc-inner">
    <header class="toc-header">
      <div class="toc-header-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="10" x2="16" y2="10"/>
          <line x1="4" y1="14" x2="14" y2="14"/>
          <line x1="4" y1="18" x2="10" y2="18"/>
          <circle cx="6" cy="6" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="6" cy="10" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="6" cy="14" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="6" cy="18" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <span class="toc-label">On This Page</span>
      <div class="toc-header-line" aria-hidden="true"></div>
    </header>

    <nav class="toc-nav" aria-label="Table of contents">
      <ul class="toc-list" id="toc-list">
        {(items.length > 0 ? items : []).map((item) => {
          if (item.depth > maxDepth) return null;
          return (
            <li key={item.id}>
              <a
                href={`#${item.id}`}
                class={`toc-link toc-depth-${item.depth > 2 ? 3 : 2}`}
                data-toc-depth={item.depth}
              >
                <span class="toc-dot" aria-hidden="true"></span>
                <span class="toc-text">{item.text}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <footer class="toc-footer">
      <div class="toc-footer-line" aria-hidden="true"></div>
      <span class="toc-scroll-hint">
        <svg class="toc-scroll-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
        Scroll to navigate
      </span>
    </footer>
  </div>
</div>

<script>
  (function () {
    'use strict';

    function setupToc(tocEl) {
      if (tocEl.dataset.tocInitialised === 'true') return;
      tocEl.dataset.tocInitialised = 'true';

      var tocList = tocEl.querySelector('.toc-list');
      if (!tocList) return;

      var contentRoot = tocEl.ownerDocument.querySelector('.post-content, article, main');
      if (!contentRoot) return;

      var headings = [].slice.call(
        contentRoot.querySelectorAll('h2[id], h3[id], h4[id]')
      );

      if (!headings.length) return;

      var existingIds = {};
      [].slice.call(tocList.querySelectorAll('a[href^="#"]')).forEach(function (link) {
        var href = link.getAttribute('href') || '';
        existingIds[href.replace(/^#/, '')] = true;
      });

      var fragment = document.createDocumentFragment();
      headings.forEach(function (heading) {
        var id = heading.id;
        if (existingIds[id]) return;
        var text = (heading.textContent || '').trim();
        if (!text) return;

        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + id;
        a.className = 'toc-link toc-depth-' +
          (parseInt(heading.tagName.replace('H', ''), 10) > 2 ? '3' : '2');
        a.dataset.tocDepth = heading.tagName.replace('H', '');

        var dot = document.createElement('span');
        dot.className = 'toc-dot';
        dot.setAttribute('aria-hidden', 'true');

        var span = document.createElement('span');
        span.className = 'toc-text';
        span.textContent = text;

        a.appendChild(dot);
        a.appendChild(span);
        li.appendChild(a);
        fragment.appendChild(li);
      });

      tocList.appendChild(fragment);

      var links = [].slice.call(tocList.querySelectorAll('a[href^="#"]'));
      if (!links.length) return;

      var currentActiveId = null;

      function setActive(id) {
        if (currentActiveId === id) return;
        currentActiveId = id;
        links.forEach(function (link) {
          var href = link.getAttribute('href') || '';
          if (href === '#' + id) {
            link.classList.add('toc-active');
          } else {
            link.classList.remove('toc-active');
          }
        });
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        { 
          rootMargin: '-80px 0px -70% 0px', 
          threshold: 0 
        }
      );

      headings.forEach(function (heading) {
        observer.observe(heading);
      });

      links.forEach(function (link) {
        link.addEventListener('click', function (e) {
          e.preventDefault();
          var href = link.getAttribute('href') || '';
          if (href.startsWith('#')) {
            var targetId = href.replace(/^#/, '');
            var target = tocEl.ownerDocument.getElementById(targetId);
            if (target) {
              var navHeight = 80;
              var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - navHeight - 20;
              
              window.scrollTo({
                top: targetPosition,
                behavior: 'smooth'
              });
              
              setTimeout(function () {
                setActive(targetId);
              }, 150);
            }
          }
        });
      });

      var scrollTimeout;
      window.addEventListener('scroll', function () {
        if (scrollTimeout) {
          window.cancelAnimationFrame(scrollTimeout);
        }
        scrollTimeout = window.requestAnimationFrame(function () {
          var scrollPos = window.scrollY + 100;
          var activeHeading = null;
          
          headings.forEach(function (heading) {
            var headingTop = heading.getBoundingClientRect().top + window.pageYOffset;
            if (headingTop <= scrollPos) {
              activeHeading = heading;
            }
          });
          
          if (activeHeading && activeHeading.id !== currentActiveId) {
            setActive(activeHeading.id);
          }
        });
      }, { passive: true });
    }

    function init() {
      [].slice.call(document.querySelectorAll('.toc')).forEach(function (tocEl) {
        setupToc(tocEl);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('astro:page-load', init);
  })();
</script>

<style is:global>
  /* ============================================
     DESIGN TOKENS
     ============================================ */
  .toc {
    --toc-bg-page: #0B0F1A;
    --toc-bg-card: rgba(17, 24, 39, 0.7);
    --toc-bg-hover: rgba(139, 92, 246, 0.08);
    --toc-bg-active: rgba(139, 92, 246, 0.12);

    --toc-text-primary: #F1F5F9;
    --toc-text-secondary: #94A3B8;
    --toc-text-muted: #64748B;
    --toc-text-accent: #A78BFA;

    --toc-accent-purple: #8B5CF6;
    --toc-accent-purple-light: #A78BFA;
    --toc-accent-pink: #EC4899;

    --toc-border-subtle: rgba(148, 163, 184, 0.08);
    --toc-border-glow: rgba(139, 92, 246, 0.2);

    --toc-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --toc-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
    --toc-shadow-glow: 0 0 40px rgba(139, 92, 246, 0.15);

    --toc-radius-sm: 0.5rem;
    --toc-radius-md: 0.75rem;
    --toc-radius-lg: 1rem;
    --toc-radius-xl: 1.25rem;

    --toc-font-display: 'Space Grotesk', system-ui, sans-serif;
    --toc-font-body: 'DM Sans', system-ui, sans-serif;

    --toc-transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    --toc-transition-base: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    --toc-transition-spring: 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);

    --toc-dot-size: 7px;
    --toc-dot-glow: rgba(139, 92, 246, 0.5);
    --toc-indent: 1.25rem;
    --toc-nav-height: 80px;

    position: relative;
    font-family: var(--toc-font-body);
  }

  [data-theme="light"] .toc {
    --toc-bg-page: #F1F5F9;
    --toc-bg-card: rgba(255, 255, 255, 0.85);
    --toc-bg-hover: rgba(124, 58, 237, 0.06);
    --toc-bg-active: rgba(124, 58, 237, 0.1);

    --toc-text-primary: #0F172A;
    --toc-text-secondary: #334155;
    --toc-text-muted: #64748B;
    --toc-text-accent: #6D28D9;

    --toc-accent-purple: #7C3AED;
    --toc-accent-purple-light: #8B5CF6;
    --toc-accent-pink: #DB2777;

    --toc-border-subtle: rgba(0, 0, 0, 0.06);
    --toc-border-glow: rgba(124, 58, 237, 0.15);

    --toc-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.06);
    --toc-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
    --toc-shadow-glow: 0 0 40px rgba(124, 58, 237, 0.08);
  }

  /* ============================================
     LAYOUT VARIANTS
     ============================================ */

  /* ---- Sidebar ---- */
  .toc[data-layout='sidebar'] {
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    min-width: 220px;
  }

  .toc[data-layout='sidebar']::-webkit-scrollbar { width: 3px; }
  .toc[data-layout='sidebar']::-webkit-scrollbar-track { background: transparent; }
  .toc[data-layout='sidebar']::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.15);
    border-radius: 3px;
  }
  .toc[data-layout='sidebar']::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 184, 0.3);
  }

  /* ---- Card ---- */
  .toc[data-layout='card'] {
    max-width: 400px;
    margin: 3rem auto 0;
    background: var(--toc-bg-card);
    border: 1px solid var(--toc-border-subtle);
    border-radius: var(--toc-radius-xl);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    box-shadow:
      var(--toc-shadow-md),
      0 0 0 1px rgba(139, 92, 246, 0.05) inset,
      0 1px 0 rgba(255, 255, 255, 0.03) inset;
    overflow: hidden;
  }

  .toc[data-layout='card']::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(ellipse 80% 50% at 20% 0%, rgba(139, 92, 246, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(236, 72, 153, 0.05) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ---- Minimal ---- */
  .toc[data-layout='minimal'] {
    max-width: 300px;
    padding: 0;
    background: transparent;
  }

  /* ============================================
     INNER WRAPPER
     ============================================ */
  .toc-inner {
    padding: 1.5rem 1.25rem;
    position: relative;
    z-index: 1;
  }

  .toc[data-layout='card'] .toc-inner { padding: 1.75rem 1.5rem; }
  .toc[data-layout='minimal'] .toc-inner { padding: 0; }

  /* ============================================
     HEADER
     ============================================ */
  .toc-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    position: relative;
  }

  .toc-header-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    color: var(--toc-text-accent);
    flex-shrink: 0;
    filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.35));
  }

  .toc-header-icon svg { width: 100%; height: 100%; }

  .toc-label {
    font-family: var(--toc-font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--toc-text-accent);
    white-space: nowrap;
    text-shadow: 0 0 16px rgba(139, 92, 246, 0.25);
  }

  .toc-header-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(139, 92, 246, 0.3) 0%,
      rgba(139, 92, 246, 0.08) 60%,
      transparent 100%
    );
    margin-left: 0.25rem;
    position: relative;
    overflow: hidden;
  }

  .toc-header-line::after {
    content: '';
    position: absolute;
    left: -30px;
    top: -1px;
    width: 30px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--toc-text-accent), transparent);
    border-radius: 2px;
    animation: tocShimmer 3s ease-in-out infinite;
  }

  @keyframes tocShimmer {
    0% { left: -30px; opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  .toc[data-layout='minimal'] .toc-header {
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
  }

  /* ============================================
     NAVIGATION
     ============================================ */
  .toc-nav { display: flex; flex-direction: column; }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    position: relative;
  }

  /* Vertical guide line */
  .toc-list li {
    line-height: 1;
    position: relative;
  }

  /* ============================================
     LINK
     ============================================ */
  .toc-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--toc-text-secondary);
    text-decoration: none;
    font-family: var(--toc-font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.55rem 0.875rem;
    border-radius: var(--toc-radius-sm);
    transition:
      color var(--toc-transition-base),
      background var(--toc-transition-base),
      transform var(--toc-transition-spring),
      box-shadow var(--toc-transition-base);
    position: relative;
    line-height: 1.5;
    overflow: hidden;
  }

  /* Hide depth 4+ */
  .toc-link[data-toc-depth='4'],
  .toc-link[data-toc-depth='5'] { display: none; }

  /* Left glow bar */
  .toc-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleY(0);
    width: 2.5px;
    height: 55%;
    background: linear-gradient(180deg, transparent, var(--toc-text-accent), transparent);
    border-radius: 2px;
    transition: transform var(--toc-transition-spring);
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.4);
  }

  /* ============================================
     DOT INDICATOR
     ============================================ */
  .toc-dot {
    display: block;
    width: var(--toc-dot-size);
    height: var(--toc-dot-size);
    border-radius: 50%;
    flex-shrink: 0;
    background: rgba(148, 163, 184, 0.2);
    transition:
      background var(--toc-transition-base),
      transform var(--toc-transition-spring),
      box-shadow var(--toc-transition-base);
    position: relative;
  }

  .toc-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: transparent;
    transition: background var(--toc-transition-base);
  }

  .toc-text {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
    transition: color var(--toc-transition-base);
  }

  /* ============================================
     HOVER STATE
     ============================================ */
  .toc-link:hover {
    color: var(--toc-text-primary);
    background: var(--toc-bg-hover);
    transform: translateX(5px);
  }

  .toc-link:hover::before {
    transform: translateY(-50%) scaleY(1);
  }

  .toc-link:hover .toc-dot {
    background: linear-gradient(135deg, var(--toc-accent-purple), var(--toc-accent-pink));
    box-shadow:
      0 0 10px var(--toc-dot-glow),
      0 0 22px rgba(139, 92, 246, 0.25);
    transform: scale(1.5);
  }

  .toc-link:hover .toc-dot::after {
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
  }

  /* ============================================
     ACTIVE STATE
     ============================================ */
  .toc-link.toc-active {
    color: var(--toc-text-primary);
    background: var(--toc-bg-active);
    box-shadow:
      0 0 0 1px rgba(139, 92, 246, 0.12),
      0 0 24px rgba(139, 92, 246, 0.08);
  }

  .toc-link.toc-active::before {
    transform: translateY(-50%) scaleY(1);
  }

  .toc-link.toc-active .toc-dot {
    background: linear-gradient(135deg, var(--toc-accent-purple), var(--toc-accent-pink));
    box-shadow:
      0 0 14px var(--toc-dot-glow),
      0 0 28px rgba(139, 92, 246, 0.35),
      0 0 42px rgba(236, 72, 153, 0.15);
    transform: scale(1.55);
  }

  .toc-link.toc-active .toc-dot::after {
    background: radial-gradient(circle, rgba(139, 92, 246, 0.18) 0%, transparent 70%);
  }

  .toc-link.toc-active .toc-text {
    color: var(--toc-text-primary);
    text-shadow: 0 0 16px rgba(139, 92, 246, 0.2);
  }

  /* ============================================
     DEPTH 3 NESTING
     ============================================ */
  .toc-depth-3 {
    padding-left: calc(var(--toc-indent) + 0.875rem + var(--toc-dot-size));
  }

  .toc-depth-3::after {
    content: '';
    position: absolute;
    left: calc(0.875rem + var(--toc-dot-size) / 2);
    top: 0.75rem;
    bottom: 0.75rem;
    width: 1px;
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.15), rgba(148, 163, 184, 0.04));
    border-radius: 1px;
  }

  /* ============================================
     TYPOGRAPHY PER DEPTH
     ============================================ */
  .toc-link.toc-depth-2 .toc-text {
    font-weight: 600;
    font-size: 0.84rem;
  }

  .toc-link.toc-depth-3 .toc-text {
    font-weight: 400;
    font-size: 0.79rem;
    opacity: 0.85;
  }

  /* ============================================
     FOOTER
     ============================================ */
  .toc-footer {
    margin-top: 1.25rem;
    padding-top: 0.875rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .toc-footer-line {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(139, 92, 246, 0.2) 0%,
      rgba(139, 92, 246, 0.06) 50%,
      transparent 100%
    );
    position: relative;
    overflow: hidden;
  }

  .toc-footer-line::after {
    content: '';
    position: absolute;
    left: 0;
    top: -1px;
    width: 14px;
    height: 3px;
    background: var(--toc-text-accent);
    border-radius: 2px;
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.4);
  }

  .toc[data-layout='minimal'] .toc-footer { display: none; }

  .toc-scroll-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--toc-font-display);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.4);
    transition: color var(--toc-transition-base);
  }

  .toc-scroll-icon {
    width: 0.85em;
    height: 0.85em;
    opacity: 0.5;
    animation: tocBounce 2.2s ease-in-out infinite;
    transition: opacity var(--toc-transition-base);
  }

  .toc:hover .toc-scroll-hint { color: rgba(148, 163, 184, 0.65); }
  .toc:hover .toc-scroll-icon { opacity: 0.8; }

  @keyframes tocBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }

  /* ============================================
     ACCESSIBILITY
     ============================================ */
  .toc-link:focus-visible {
    outline: 2px solid rgba(139, 92, 246, 0.5);
    outline-offset: 2px;
    border-radius: var(--toc-radius-sm);
  }

  /* ============================================
     ENTRANCE ANIMATIONS
     ============================================ */
  .toc {
    animation: tocFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes tocFadeIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Stagger list items */
  .toc-list li {
    animation: tocItemSlide 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .toc-list li:nth-child(1) { animation-delay: 0.05s; }
  .toc-list li:nth-child(2) { animation-delay: 0.1s; }
  .toc-list li:nth-child(3) { animation-delay: 0.15s; }
  .toc-list li:nth-child(4) { animation-delay: 0.2s; }
  .toc-list li:nth-child(5) { animation-delay: 0.25s; }
  .toc-list li:nth-child(6) { animation-delay: 0.3s; }
  .toc-list li:nth-child(7) { animation-delay: 0.35s; }
  .toc-list li:nth-child(8) { animation-delay: 0.4s; }
  .toc-list li:nth-child(9) { animation-delay: 0.45s; }
  .toc-list li:nth-child(10) { animation-delay: 0.5s; }

  @keyframes tocItemSlide {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ============================================
     REDUCED MOTION
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    .toc, .toc-list li { animation: none; }
    .toc-link, .toc-dot, .toc-scroll-icon, .toc-link::before { transition: none; }
    .toc-header-line::after { animation: none; }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 1100px) {
    .toc[data-layout='sidebar'] {
      position: static;
      max-height: none;
      max-width: 100%;
      min-width: unset;
    }

    .toc[data-layout='sidebar'] .toc-list::before { display: none; }
    .toc-depth-3::after { display: none; }
  }

  @media (max-width: 640px) {
    .toc[data-layout='card'] {
      max-width: 100%;
      margin: 2rem 0 0;
      border-radius: var(--toc-radius-md);
    }

    .toc-inner { padding: 1.25rem 1rem; }
    .toc[data-layout='card'] .toc-inner { padding: 1.5rem 1.25rem; }

    .toc-link {
      padding: 0.5rem 0.625rem;
      font-size: 0.8rem;
    }

    .toc-link::before { display: none; }

    .toc-depth-3 {
